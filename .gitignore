# Environment & secrets
.env
.env.*
!.env.example
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Notebook checkpoints
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

